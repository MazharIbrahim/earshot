# Earshot backend — example env. Copy to .env and fill in for local dev.
# In production these come from your hosting provider's secret store.

# ---------- Storage (audio files) ----------
# Cloudflare R2 has free egress; ideal for streaming media.
EARSHOT_STORAGE=r2
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET=earshot-takes
R2_PUBLIC_BASE=https://pub-xxxxxxxxxxxx.r2.dev

# Optional: set true if/when you wire up "download original WAV" as a
# Pro feature. By default we only push the small Opus to R2.
# EARSHOT_UPLOAD_WAV=false

# ---------- Database (metadata) ----------
# 'sqlite' = local file (dev). 'supabase' = Postgres via PostgREST (prod).
EARSHOT_DB=supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SERVICE_KEY=sb_secret_xxx

# ---------- Tunnel (dev only) ----------
# Cloudflare quick tunnel for exposing localhost. Set to 'off' in
# production (Render gives you a stable URL).
# EARSHOT_TUNNEL=off
